<ui:FluentWindow x:Class="ApexTodo.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:converters="clr-namespace:ApexTodo.Windows.Converters"
        Title="ApexTodo" Width="360" Height="500"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:DueTimeToTextConverter x:Key="DueTimeToText"/>
        <converters:DueTimeToColorConverter x:Key="DueTimeToColor"/>
    </Window.Resources>

    <Grid>
        <!-- ===== Layer 1: Main content (blurred when settings open) ===== -->
        <Grid x:Name="MainContent">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowSettings}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Height="32" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.Background>
                    <SolidColorBrush Color="{ui:ThemeResource LayerFillColorDefault}" Opacity="0.8"/>
                </Grid.Background>
                <TextBlock Text="ApexTodo" VerticalAlignment="Center" Margin="12,0,0,0"
                           FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="PassthroughBtn" Appearance="Transparent"
                               Icon="{ui:SymbolIcon Eye24}" Width="46" Height="32"
                               Click="PassthroughButton_Click" ToolTip="鼠标穿透"/>
                    <ui:Button x:Name="PinBtn" Appearance="Transparent"
                               Icon="{ui:SymbolIcon Pin24}" Width="46" Height="32"
                               Click="PinButton_Click" ToolTip="点击置顶"/>
                    <ui:Button Appearance="Transparent"
                               Icon="{ui:SymbolIcon Subtract24}" Width="46" Height="32"
                               Click="MinimizeButton_Click"/>
                    <ui:Button Appearance="Transparent"
                               Icon="{ui:SymbolIcon Dismiss24}" Width="46" Height="32"
                               Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Task input -->
            <Grid Grid.Row="1" Margin="12,8,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="InputBox" Grid.Column="0"
                            PlaceholderText="输入任务..."
                            Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                            KeyDown="InputBox_KeyDown"/>
                <ui:Button Grid.Column="1" Content="添加" Margin="8,0,0,0"
                           Appearance="Primary"
                           Command="{Binding AddTaskCommand}"/>
            </Grid>

            <!-- Due date quick options -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,4,12,0">
                <TextBlock Text="截止:" VerticalAlignment="Center" FontSize="12"
                           Foreground="#6C7086" Margin="0,0,8,0"/>
                <Button x:Name="Chip1h" Content="1小时" Margin="0,0,4,0" Padding="8,2" FontSize="11"
                        Click="DueChip_Click" Tag="1小时"
                        Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                <Button x:Name="Chip1d" Content="1天" Margin="0,0,4,0" Padding="8,2" FontSize="11"
                        Click="DueChip_Click" Tag="1天"
                        Background="#89B4FA" Foreground="#1E1E2E" BorderThickness="0"/>
                <Button x:Name="Chip3d" Content="3天" Margin="0,0,4,0" Padding="8,2" FontSize="11"
                        Click="DueChip_Click" Tag="3天"
                        Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                <Button x:Name="Chip5d" Content="5天" Margin="0,0,4,0" Padding="8,2" FontSize="11"
                        Click="DueChip_Click" Tag="5天"
                        Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                <Button x:Name="Chip1m" Content="1个月" Margin="0,0,4,0" Padding="8,2" FontSize="11"
                        Click="DueChip_Click" Tag="1个月"
                        Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
            </StackPanel>

            <!-- Task list -->
            <Grid Grid.Row="3" Margin="12,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="待办" FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                <ListView Grid.Row="1" ItemsSource="{Binding OpenTasks}"
                          Background="Transparent" BorderThickness="0"
                          SelectionMode="Single" x:Name="OpenTasksList"
                          AllowDrop="True" Drop="OpenTasks_Drop" DragOver="OpenTasks_DragOver">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding Completed}"
                                          Command="{Binding DataContext.ToggleTaskCommand,
                                              RelativeSource={RelativeSource AncestorType=ListView}}"
                                          CommandParameter="{Binding}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         LostFocus="TaskText_LostFocus"
                                         Tag="{Binding Id}"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="4,0"
                                           Cursor="Hand" MouseLeftButtonDown="DueText_Click"
                                           Tag="{Binding}"
                                           Text="{Binding DueAt, Converter={StaticResource DueTimeToText}}"
                                           Foreground="{Binding DueAt, Converter={StaticResource DueTimeToColor}}"
                                           Visibility="{Binding DueAt, Converter={StaticResource NullToVis}}"/>
                                <ui:Button Grid.Column="3" Appearance="Transparent"
                                           Icon="{ui:SymbolIcon Dismiss24}" Width="32" Height="32"
                                           Command="{Binding DataContext.DeleteTaskCommand,
                                               RelativeSource={RelativeSource AncestorType=ListView}}"
                                           CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,4"
                            MouseLeftButtonDown="ToggleCompleted_Click" Cursor="Hand">
                    <TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#x25B6; 已完成"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowCompleted}" Value="True">
                                        <Setter Property="Text" Value="&#x25BC; 已完成"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CompletedTasks.Count}" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                               FontSize="12" Margin="8,0,0,0"/>
                </StackPanel>

                <ListView Grid.Row="3" ItemsSource="{Binding CompletedTasks}"
                          Background="Transparent" BorderThickness="0"
                          Visibility="{Binding ShowCompleted, Converter={StaticResource BoolToVis}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2" Opacity="0.6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding Completed}"
                                          Command="{Binding DataContext.ToggleTaskCommand,
                                              RelativeSource={RelativeSource AncestorType=ListView}}"
                                          CommandParameter="{Binding}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Text}"
                                           TextDecorations="Strikethrough"
                                           Foreground="#9399B2"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="4,0"
                                           Text="{Binding DueAt, Converter={StaticResource DueTimeToText}, ConverterParameter=completed}"
                                           Foreground="{Binding DueAt, Converter={StaticResource DueTimeToColor}, ConverterParameter=completed}"
                                           Visibility="{Binding DueAt, Converter={StaticResource NullToVis}}"/>
                                <ui:Button Grid.Column="3" Appearance="Transparent"
                                           Icon="{ui:SymbolIcon Dismiss24}" Width="32" Height="32"
                                           Command="{Binding DataContext.DeleteTaskCommand,
                                               RelativeSource={RelativeSource AncestorType=ListView}}"
                                           CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Bottom bar -->
            <Grid Grid.Row="4" Margin="12,4,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding SyncMessage}"
                           Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Content="同步" Margin="0,0,4,0" Command="{Binding RunSyncCommand}"
                               Appearance="Secondary"/>
                    <ui:Button Content="设置" Command="{Binding ToggleSettingsCommand}"
                               Appearance="Secondary"/>
                </StackPanel>
            </Grid>

            <!-- Due date flyout backdrop -->
            <Border Background="#66000000"
                    Visibility="{Binding ShowDueFlyout, Converter={StaticResource BoolToVis}}"
                    MouseLeftButtonDown="CloseDueFlyout_Click"/>

            <!-- Due date flyout -->
            <Border Margin="40,100,40,100" Padding="0" CornerRadius="6"
                    Background="#313244" BorderBrush="#45475A" BorderThickness="1"
                    Visibility="{Binding ShowDueFlyout, Converter={StaticResource BoolToVis}}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="修改截止时间" FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4" Margin="0,0,0,12"/>
                    <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                        <Button Content="1小时" Margin="0,0,4,4" Padding="8,4" Click="FlyoutDueChip_Click" Tag="1小时"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                        <Button Content="1天" Margin="0,0,4,4" Padding="8,4" Click="FlyoutDueChip_Click" Tag="1天"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                        <Button Content="3天" Margin="0,0,4,4" Padding="8,4" Click="FlyoutDueChip_Click" Tag="3天"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                        <Button Content="5天" Margin="0,0,4,4" Padding="8,4" Click="FlyoutDueChip_Click" Tag="5天"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                        <Button Content="1个月" Margin="0,0,4,4" Padding="8,4" Click="FlyoutDueChip_Click" Tag="1个月"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                    </WrapPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="清除" Click="ClearDue_Click" Margin="0,0,8,0"
                                Background="#F38BA8" Foreground="#1E1E2E" BorderThickness="0" Padding="12,6"/>
                        <Button Content="关闭" Click="CloseDueFlyout_Click"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1" Padding="12,6"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- ===== Layer 2: Overlays (NOT blurred) ===== -->
        <!-- Settings backdrop mask -->
        <Border Background="#66000000"
                Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                MouseLeftButtonDown="CancelSettings_Click"/>

        <!-- Settings panel -->
        <ui:Card Margin="20,48,20,20" Padding="0"
                 Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="设置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="主题" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:Button x:Name="ThemeDarkBtn" Content="深色" Padding="12,4" Margin="0,0,4,0"
                                       Click="ThemeDark_Click"/>
                            <ui:Button x:Name="ThemeLightBtn" Content="浅色" Padding="12,4" Margin="0,0,4,0"
                                       Click="ThemeLight_Click"/>
                            <ui:Button x:Name="ThemeSystemBtn" Content="跟随系统" Padding="12,4"
                                       Click="ThemeSystem_Click"/>
                        </StackPanel>
                        <CheckBox Content="窗口置顶" IsChecked="{Binding Settings.AlwaysOnTop}"
                                  Checked="AlwaysOnTop_Changed" Unchecked="AlwaysOnTop_Changed"
                                  Margin="0,0,0,8"/>
                        <CheckBox Content="开机自启" IsChecked="{Binding Settings.LaunchAtStartup}" Margin="0,0,0,8"/>
                        <CheckBox Content="桌面嵌入模式" IsChecked="{Binding Settings.DesktopPinned}" Margin="0,0,0,8"/>

                        <TextBlock Text="透明度" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,8,0,4"/>
                        <Slider Minimum="0.35" Maximum="1.0" Value="{Binding Settings.WindowOpacity}"
                                SmallChange="0.01" LargeChange="0.05"
                                ValueChanged="OpacitySlider_Changed"/>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="WebDAV 同步" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <CheckBox Content="启用 WebDAV" IsChecked="{Binding Settings.WebDav.Enabled}" Margin="0,0,0,8"/>
                        <TextBlock Text="服务器地址" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding Settings.WebDav.Url}" Margin="0,0,0,8"/>
                        <TextBlock Text="用户名" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding Settings.WebDav.Username}" Margin="0,0,0,8"/>
                        <TextBlock Text="密码" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ui:PasswordBox Margin="0,0,0,8"/>
                        <TextBlock Text="远程路径" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding Settings.WebDav.RemotePath}" Margin="0,0,0,8"/>
                        <TextBlock Text="同步间隔(分钟)" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding Settings.WebDav.IntervalMinutes}" Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <ui:Button Content="保存" Appearance="Primary" Command="{Binding SaveSettingsCommand}" Margin="0,0,8,0"/>
                    <ui:Button Content="取消" Click="CancelSettings_Click"/>
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- Toast -->
        <ui:Card HorizontalAlignment="Center" VerticalAlignment="Top"
                 Margin="40,50,40,0" Padding="16,10"
                 Visibility="{Binding ShowToast, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{ui:ThemeResource SystemFillColorSuccessBrush}" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ToastMessage}" FontSize="13"/>
            </StackPanel>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
