<Window x:Class="ApexTodo.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ApexTodo.Windows.Converters"
        Title="ApexTodo" Width="360" Height="500"
        WindowStyle="None" AllowsTransparency="True"
        Background="#1E1E2E" Foreground="#CDD6F4"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="True">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
    </Window.Resources>
    <Border CornerRadius="8" BorderBrush="#45475A" BorderThickness="1" Background="#1E1E2E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#181825" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="ApexTodo" VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="12" Foreground="#6C7086"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                        <Button x:Name="PinBtn" Content="&#x25A1;" Width="30" Height="28"
                                FontSize="14" Click="PinButton_Click" ToolTip="置顶切换"
                                Background="Transparent" BorderThickness="0" Foreground="#89B4FA"/>
                        <Button Content="&#x2014;" Width="30" Height="28"
                                FontSize="14" Click="MinimizeButton_Click"
                                Background="Transparent" BorderThickness="0" Foreground="#6C7086"/>
                        <Button Content="&#x2715;" Width="30" Height="28"
                                FontSize="14" Click="CloseButton_Click"
                                Background="Transparent" BorderThickness="0" Foreground="#F38BA8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Task input -->
            <Grid Grid.Row="1" Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Grid.Column="0"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="InputBox_KeyDown"
                         VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="添加" Margin="8,0,0,0"
                        Command="{Binding AddTaskCommand}"
                        Background="#313244" Foreground="#CDD6F4"
                        BorderBrush="#45475A" BorderThickness="1"
                        Padding="12,6"/>
            </Grid>

            <!-- Task list -->
            <Grid Grid.Row="2" Margin="12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Open tasks -->
                <TextBlock Grid.Row="0" Text="待办" FontSize="12" Foreground="#6C7086" Margin="0,0,0,4"/>
                <ListView Grid.Row="1" ItemsSource="{Binding OpenTasks}"
                          Background="Transparent" BorderThickness="0"
                          SelectionMode="Single" x:Name="OpenTasksList"
                          AllowDrop="True" Drop="OpenTasks_Drop" DragOver="OpenTasks_DragOver">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding Completed}"
                                          Command="{Binding DataContext.ToggleTaskCommand,
                                              RelativeSource={RelativeSource AncestorType=ListView}}"
                                          CommandParameter="{Binding}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#CDD6F4" VerticalContentAlignment="Center"
                                         LostFocus="TaskText_LostFocus"
                                         Tag="{Binding Id}"/>
                                <Button Grid.Column="2" Content="&#x2715;" Width="24" Height="24"
                                        FontSize="10" Background="Transparent" BorderThickness="0"
                                        Foreground="#6C7086"
                                        Command="{Binding DataContext.DeleteTaskCommand,
                                            RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Completed fold -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,4"
                            MouseLeftButtonDown="ToggleCompleted_Click" Cursor="Hand">
                    <TextBlock Foreground="#6C7086" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="▶ 已完成"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowCompleted}" Value="True">
                                        <Setter Property="Text" Value="▼ 已完成"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CompletedTasks.Count}" Foreground="#6C7086"
                               FontSize="12" Margin="8,0,0,0"/>
                </StackPanel>

                <ListView Grid.Row="3" ItemsSource="{Binding CompletedTasks}"
                          Background="Transparent" BorderThickness="0"
                          Visibility="{Binding ShowCompleted, Converter={StaticResource BoolToVis}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2" Opacity="0.6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding Completed}"
                                          Command="{Binding DataContext.ToggleTaskCommand,
                                              RelativeSource={RelativeSource AncestorType=ListView}}"
                                          CommandParameter="{Binding}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Text}"
                                           Foreground="#6C7086" TextDecorations="Strikethrough"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="&#x2715;" Width="24" Height="24"
                                        FontSize="10" Background="Transparent" BorderThickness="0"
                                        Foreground="#6C7086"
                                        Command="{Binding DataContext.DeleteTaskCommand,
                                            RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Bottom bar -->
            <Grid Grid.Row="3" Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding SyncMessage}" Foreground="#6C7086"
                           FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="同步" Margin="0,0,4,0" Command="{Binding RunSyncCommand}"
                            FontSize="11" Padding="8,4"
                            Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                    <Button Content="设置" Command="{Binding ToggleSettingsCommand}"
                            FontSize="11" Padding="8,4"
                            Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"/>
                </StackPanel>
            </Grid>

            <!-- Settings overlay -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                    Background="#CC1E1E2E" CornerRadius="8">
                <Grid Margin="20,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="设置" FontSize="16" Foreground="#CDD6F4" Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <CheckBox Content="窗口置顶" IsChecked="{Binding Settings.AlwaysOnTop}"
                                      Checked="AlwaysOnTop_Changed" Unchecked="AlwaysOnTop_Changed"
                                      Margin="0,0,0,8"/>
                            <CheckBox Content="开机自启" IsChecked="{Binding Settings.LaunchAtStartup}" Margin="0,0,0,8"/>
                            <CheckBox Content="桌面嵌入模式" IsChecked="{Binding Settings.DesktopPinned}" Margin="0,0,0,8"/>

                            <TextBlock Text="透明度" Foreground="#6C7086" FontSize="12" Margin="0,8,0,4"/>
                            <Slider Minimum="0.35" Maximum="1.0" Value="{Binding Settings.WindowOpacity}"
                                    SmallChange="0.01" LargeChange="0.05"
                                    ValueChanged="OpacitySlider_Changed"/>

                            <Separator Background="#45475A" Margin="0,12,0,12"/>

                            <TextBlock Text="WebDAV 同步" FontSize="14" Foreground="#CDD6F4" Margin="0,0,0,8"/>
                            <CheckBox Content="启用 WebDAV" IsChecked="{Binding Settings.WebDav.Enabled}" Margin="0,0,0,8"/>
                            <TextBlock Text="服务器地址" Foreground="#6C7086" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Settings.WebDav.Url}" Margin="0,0,0,8"/>
                            <TextBlock Text="用户名" Foreground="#6C7086" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Settings.WebDav.Username}" Margin="0,0,0,8"/>
                            <TextBlock Text="密码" Foreground="#6C7086" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Settings.WebDav.Password}" Margin="0,0,0,8"/>
                            <TextBlock Text="远程路径" Foreground="#6C7086" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Settings.WebDav.RemotePath}" Margin="0,0,0,8"/>
                            <TextBlock Text="同步间隔(分钟)" Foreground="#6C7086" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Settings.WebDav.IntervalMinutes}" Margin="0,0,0,8"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="保存" Command="{Binding SaveSettingsCommand}" Margin="0,0,8,0"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1" Padding="12,6"/>
                        <Button Content="取消" Click="CancelSettings_Click"
                                Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1" Padding="12,6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toast -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    Visibility="{Binding ShowToast, Converter={StaticResource BoolToVis}}"
                    Background="#CC313244" CornerRadius="6"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="40,50,40,0" Padding="16,10">
                <TextBlock Text="{Binding ToastMessage}" Foreground="#A6E3A1" FontSize="13"/>
            </Border>
        </Grid>
    </Border>
</Window>
